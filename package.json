{
  "name": "mp3player",
  "version": "1.0.0",
  "description": "Minimalist MP3 плеер в стиле Winamp на Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.mp3player.app",
    "productName": "MP3 Player",
    "mac": {
      "category": "public.app-category.music",
      "icon": "mp3player-icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "MP3 Player",
      "icon": "mp3player-icon.png",
      "iconSize": 128
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json",
      "mp3player-icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
